# PostgreSQL connection string — set automatically by Railway when you add a Postgres plugin
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/announce_bot

# Slack Bot Token (starts with xoxb-)
# Get from: api.slack.com/apps → Your App → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-token-here

# Slack Signing Secret
# Get from: api.slack.com/apps → Your App → Basic Information → Signing Secret
SLACK_SIGNING_SECRET=your-signing-secret-here

# Slack App-Level Token (starts with xapp-) — required for Socket Mode
# Get from: api.slack.com/apps → Your App → Basic Information → App-Level Tokens
# Create one with: connections:write scope
SLACK_APP_TOKEN=xapp-your-app-token-here

# Notion Integration (for auto-syncing read receipts to Notion)
# Get from: notion.so/my-integrations → your integration → Internal Integration Secret
NOTION_API_KEY=secret_your-key-here
# The Announcement Tracker database ID (already set for your workspace)
NOTION_DATABASE_ID=2c1c5fe9246f4a6c93743f4bf29d255f

# Optional: port for HTTP mode (default 3456)
PORT=3456
